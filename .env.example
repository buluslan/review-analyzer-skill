# ==================== API 密钥配置 ====================

# ScraperAPI Key (推荐，用于抓取亚马逊评论)
# 获取地址: https://www.scraperapi.com/
# 免费额度: 5,000 请求/月
SCRAPERAPI_KEY=your_scraperapi_key_here

# Apify API Key (备选，用于抓取亚马逊评论)
# 获取地址: https://console.apify.com/api-keys
# 注意: 免费版单次最多采集10条评论
APIFY_API_KEY=your_apify_api_key_here

# Gemini API Key (必需，用于 AI 打标和洞察分析)
# 获取地址: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ==================== 模型配置 ====================

# 打标模型 (默认: Gemini 3 Flash Preview)
TAGGING_MODEL=gemini-3-flash-preview

# 洞察分析模型 (默认: Gemini 3 Flash Preview)
INSIGHTS_MODEL=gemini-3-flash-preview

# HTML报告生成模型 (默认: Gemini 3 Pro Preview)
HTML_REPORT_MODEL=gemini-3-pro-preview

# ==================== 爬虫配置 ====================

# 爬虫模式 (默认: hardcoded)
# - hardcoded: 硬编码 BeautifulSoup 解析（推荐，稳定）
# - mcp: MCP 模式（需 Skill 层支持，自适应）
# - hybrid: 混合模式（hardcoded 优先，失败时降级）
CRAWLER_MODE=hardcoded

# ==================== 分析配置 ====================

# 最大获取评论数 (默认: 500)
MAX_REVIEWS=500

# 每批处理数量 (默认: 30, 范围: 20-50)
# 注意: main.py命令行参数默认为20,此处为config.py中的默认值
BATCH_SIZE=30

# ==================== 输出配置 ====================

# 是否生成 HTML 报告 (默认: true)
GENERATE_HTML=true

# ==================== 高级配置 ====================

# 最大并发子代理数 (默认: 2)
# 注意: 过高可能导致CLI超时,建议保持2
MAX_CONCURRENT_AGENTS=2

# 最多识别的用户画像数 (默认: 4)
MAX_PERSONAS=4

# 每个画像的样本数 (默认: 6, 即 3正+3负)
SAMPLES_PER_PERSONA=6
